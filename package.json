{
  "name": "soulsafe-ai-monorepo",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "npm --workspace @soulsafe/web-react run dev",
    "dev:api": "npm --workspace @soulsafe/api-node run dev",
    "build": "npm run build --workspaces",
    "lint": "npm run lint --workspaces"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
